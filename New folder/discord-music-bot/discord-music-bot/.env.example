# Discord bot token from https://discord.com/developers/applications -> your app -> Bot
DISCORD_TOKEN=your_bot_token_here

# Application/Client ID from your app's "General Information" page
CLIENT_ID=your_application_id_here

# Optional: Server (guild) ID for instant command registration during dev.
# Leave empty to register globally (takes up to 1 hour to propagate).
GUILD_ID=your_test_server_id_here
